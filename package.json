{
  "name": "kidz-planet-backend",
  "version": "1.0.0",
  "description": "NestJS Backend API for The Kidz Planet E-commerce Platform",
  "author": "The Kidz Planet",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:auth": "jest --testPathPattern='auth'",
    "test:products": "jest --testPathPattern='products'",
    "test:categories": "jest --testPathPattern='categories'",
    "test:orders": "jest --testPathPattern='orders'",
    "test:customers": "jest --testPathPattern='customers'",
    "test:discounts": "jest --testPathPattern='discounts'",
    "test:inventory": "jest --testPathPattern='inventory'",
    "test:dashboard": "jest --testPathPattern='dashboard'",
    "test:wishlist": "jest --testPathPattern='wishlist'",
    "test:reviews": "jest --testPathPattern='reviews'",
    "test:upload": "jest --testPathPattern='upload'",
    "test:newsletter": "jest --testPathPattern='newsletter'",
    "test:whatsapp": "jest --testPathPattern='whatsapp'"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "csv-parser": "^3.2.0",
    "fast-csv": "^5.0.5",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.27",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
